meta {
  name: Update Day Schedule
  type: http
  seq: 2
}

put {
  url: {{baseUrl}}/api/v1/schedule/{{dayOfWeek}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Authorization: Bearer {{token}}
  Content-Type: application/json
}

body:json {
  {
    "is_active": true,
    "sessions": [
      {
        "start_time": "09:00",
        "end_time": "13:00"
      },
      {
        "start_time": "14:00",
        "end_time": "18:00"
      }
    ]
  }
}
